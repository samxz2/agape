---
import '../styles/global.css'
import Navbar from '../components/Navbar.vue'
import CartDrawer from '../components/CartDrawer.vue'
import ToastBar from '../components/ToastBar.vue'
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'

interface Props {
  title?: string
}

const { title = 'Agape Collection Parfum' } = Astro.props
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Agape Collection Parfum - Fragancias exclusivas de lujo. Perfumes para caballero, damas, unisex y sets." />
    <meta name="theme-color" content="#3d220f" />
    <title>{title}</title>

    <!-- Preconnects -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Fonts critical -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://i.ibb.co/CpHdX08t/1001879919.png" />
    
    <!-- Vercel Analytics -->
    <Analytics />
    <SpeedInsights />
  </head>
  <body class="bg-cream-50 text-brown-800 min-h-screen">
    <Navbar client:load />
    <CartDrawer client:idle />
    <ToastBar client:idle />
    <main>
      <slot />
    </main>
    <footer class="bg-brown-800 text-cream-100 text-center py-6 mt-16 text-sm">
      <p class="font-playfair text-lg mb-1">Agape Collection Parfum</p>
      <p class="opacity-70">© 2026 · Todos los derechos reservados</p>
    </footer>
  </body>
</html>