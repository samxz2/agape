  ---
  import Layout from '../layouts/Layout.astro'
  import ProductGrid from '../components/ProductGrid.vue'
  ---

  <Layout title="Agape Collection Parfum">
  <!-- HERO -->
  <section
  class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_top,#5c3a25,transparent_60%),linear-gradient(to_bottom,#351f14,#22120b)]"
  >
  <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
  <p class="text-cream-300 uppercase tracking-[0.4em] text-xs md:text-sm mb-4">
  Bienvenido a
  </p>

  <h1 class="font-playfair text-5xl md:text-7xl text-cream-50 font-bold leading-tight">
  Agape
  <span class="block text-gold-300">
  Collection
  </span>
  </h1>

  <p class="font-playfair italic text-xl md:text-3xl text-cream-200 mt-3">
  Parfum
  </p>

  <p class="max-w-2xl mx-auto mt-6 text-sm md:text-base text-cream-200/80 leading-relaxed">
  Descubre nuestra exclusiva colección de perfumes para caballero,
  damas, unisex y sets.
  </p>

  <!-- BOTONES -->
  <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
  <a
  href="#productos"
  class="bg-gradient-to-r from-brown-700 to-brown-600 hover:from-brown-600 hover:to-brown-500 text-cream-50 font-semibold rounded-2xl transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-0.5 active:scale-95 px-8 py-4 text-sm uppercase tracking-widest"
  >
  Explorar Colección
  </a>

  <a
  href="#categorias"
  class="border border-cream-300/40 hover:border-gold-300 text-cream-100 hover:text-gold-300 rounded-2xl transition-all duration-300 px-8 py-4 text-sm uppercase tracking-widest"
  >
  Ver Categorías
  </a>
  </div>
  </div>

  <!-- blur decor -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-gold-300/10 blur-3xl rounded-full"></div>
  <div class="absolute bottom-0 right-0 w-72 h-72 bg-brown-300/10 blur-3xl rounded-full"></div>
  </section>

  <!-- CATEGORIAS -->
  <section
  id="categorias"
  class="py-16 bg-[#fffdf9]"
  >
  <div class="max-w-7xl mx-auto px-4">
  <div class="text-center mb-12">
  <h2 class="font-playfair text-3xl md:text-4xl text-brown-800 font-bold">
  Categorías
  </h2>

  <p class="text-brown-400 text-sm mt-3">
  Explora nuestra selección exclusiva
  </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
  <!-- CABALLERO -->
  <a
  href="/?categoria=caballero"
  class="group bg-white rounded-[28px] border border-cream-200 hover:border-gold-300 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl text-center"
  >
  <svg xmlns="http://www.w3.org/2000/svg"
  width="42"
  height="42"
  viewBox="0 0 24 24"
  fill="none"
  stroke="#623f29"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="mx-auto mb-4 group-hover:text-gold-400 transition-colors duration-300"
  >
  <path d="M12 2a5 5 0 1 0 0 10 5 5 0 0 0 0-10z"/>
  <path d="M2 22c0-5 5-8 10-8s10 3 10 8"/>
  </svg>

  <h3 class="font-playfair text-xl text-brown-700 font-bold">
  Caballero
  </h3>

  <p class="text-xs text-brown-400 mt-2">
  Fragancias masculinas
  </p>
  </a>

  <!-- DAMAS -->
  <a
  href="/?categoria=damas"
  class="group bg-white rounded-[28px] border border-cream-200 hover:border-gold-300 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl text-center"
  >
  <svg xmlns="http://www.w3.org/2000/svg"
  width="42"
  height="42"
  viewBox="0 0 24 24"
  fill="none"
  stroke="#623f29"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="mx-auto mb-4"
  >
  <!-- Cabeza -->
  <circle cx="12" cy="8" r="3" />
  <!-- Cuerpo / vestido -->
  <path d="M6 21v-6a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v6" />
  <!-- Brazos -->
  <path d="M8 14s-2-2-4-2" />
  <path d="M16 14s2-2 4-2" />
  <!-- Pelo (detalle femenino) -->
  <path d="M9 5a3 3 0 0 1 6 0" />
  </svg>

  <h3 class="font-playfair text-xl text-brown-700 font-bold">
  Damas
  </h3>

  <p class="text-xs text-brown-400 mt-2">
  Fragancias femeninas
  </p>
  </a>

  <!-- UNISEX -->
  <a
  href="/?categoria=unisex"
  class="group bg-white rounded-[28px] border border-cream-200 hover:border-gold-300 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl text-center"
  >
  <svg xmlns="http://www.w3.org/2000/svg"
  width="42"
  height="42"
  viewBox="0 0 24 24"
  fill="none"
  stroke="#623f29"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="mx-auto mb-4"
  >
  <path d="M12 2l1.8 5.2L19 9l-5.2 1.8L12 16l-1.8-5.2L5 9l5.2-1.8L12 2z"/>
  <path d="M19 16l.9 2.1L22 19l-2.1.9L19 22l-.9-2.1L16 19l2.1-.9L19 16z"/>
  <path d="M5 16l.9 2.1L8 19l-2.1.9L5 22l-.9-2.1L2 19l2.1-.9L5 16z"/>
  </svg>

  <h3 class="font-playfair text-xl text-brown-700 font-bold">
  Unisex
  </h3>

  <p class="text-xs text-brown-400 mt-2">
  Para todos
  </p>
  </a>

  <!-- SETS -->
  <a
  href="/?categoria=sets"
  class="group bg-white rounded-[28px] border border-cream-200 hover:border-gold-300 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl text-center"
  >
  <svg xmlns="http://www.w3.org/2000/svg"
  width="42"
  height="42"
  viewBox="0 0 24 24"
  fill="none"
  stroke="#623f29"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="mx-auto mb-4"
  >
  <rect x="3" y="8" width="18" height="12" rx="2"/>
  <path d="M3 8V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/>
  <path d="M12 6v14"/>
  </svg>

  <h3 class="font-playfair text-xl text-brown-700 font-bold">
  Sets
  </h3>

  <p class="text-xs text-brown-400 mt-2">
  Combos especiales
  </p>
  </a>
  </div>
  </div>
  </section>

  <!-- PRODUCTOS -->
  <section
  id="productos"
  class="py-16 bg-gradient-to-b from-cream-50 to-cream-100"
  >
  <div class="max-w-7xl mx-auto px-4">
  <div class="text-center mb-10">
  <h2 class="font-playfair text-3xl md:text-4xl text-brown-800 font-bold">
  Nuestra Colección
  </h2>

  <p class="text-brown-400 text-sm mt-3">
  Encuentra tu fragancia ideal
  </p>
  </div>

  <ProductGrid client:load />
  </div>
  </section>

  <!-- BOTON WHATSAPP -->
  <a
  href="https://wa.me/584127050149"
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-40 bg-green-500 hover:bg-green-400 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-[0_10px_30px_rgba(34,197,94,0.4)] hover:scale-110 transition-all duration-300"
  >
  <svg xmlns="http://www.w3.org/2000/svg"
  width="28"
  height="28"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  >
  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
  </svg>
  </a>
  </Layout>