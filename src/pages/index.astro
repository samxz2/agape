---
import Layout from '../layouts/Layout.astro'
import ProductGrid from '../components/ProductGrid.vue'
---

<Layout title="Agape Collection Parfum | Perfumes de Lujo">
  <!-- Hero Section con animación -->
  <section class="relative min-h-[70vh] md:min-h-[80vh] flex items-center justify-center overflow-hidden bg-gradient-to-br from-brown-900 via-brown-800 to-brown-700">
    <!-- Partículas decorativas -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute w-96 h-96 bg-cream-300/5 rounded-full blur-3xl animate-pulse -top-20 -left-20"></div>
      <div class="absolute w-80 h-80 bg-cream-200/5 rounded-full blur-3xl animate-pulse delay-1000 -bottom-20 -right-20"></div>
      <div class="absolute w-64 h-64 bg-brown-200/5 rounded-full blur-3xl animate-pulse delay-500 top-1/3 left-1/2 transform -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <!-- Contenido -->
    <div class="relative max-w-4xl mx-auto px-4 py-16 md:py-24 text-center">
      <div>
        <p class="text-cream-300 uppercase tracking-widest text-xs md:text-sm mb-4 font-semibold animate-slide-down">
          Bienvenido a
        </p>
        <h1 class="font-playfair text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-cream-50 font-bold mb-4 leading-tight animate-blur-in">
          Agape
          <span class="block text-cream-300">Collection</span>
        </h1>
        <p class="font-playfair text-lg md:text-2xl text-cream-200 italic mb-6 animate-fade-in">
          Parfum
        </p>
        <p class="text-cream-100 text-sm md:text-base max-w-lg mx-auto mb-8 leading-relaxed animate-fade-in">
          Descubre nuestra exclusiva colección de fragancias artesanales. 
          Perfumes que cuentan historias y despiertan emociones.
        </p>
        
        <!-- Botones -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center animate-slide-up">
          <a
            href="#productos"
            class="bg-cream-300 hover:bg-cream-200 text-brown-800 font-bold px-8 py-3.5 rounded-2xl transition-all duration-300 text-sm uppercase tracking-wider shadow-lg hover:shadow-xl transform hover:-translate-y-1 hover:scale-105 text-center"
          >
            Explorar Colección
          </a>
          <a
            href="#categorias"
            class="border-2 border-cream-300 text-cream-200 hover:text-cream-50 hover:border-cream-200 font-semibold px-8 py-3.5 rounded-2xl transition-all duration-300 text-sm uppercase tracking-wider text-center hover:scale-105"
          >
            Ver Categorías
          </a>
        </div>

        <!-- Stats -->
        <div class="flex gap-6 md:gap-10 mt-10 justify-center animate-scale-in">
          <div class="text-center hover:scale-110 transition-transform duration-300">
            <p class="text-2xl md:text-3xl font-bold text-cream-300">50+</p>
            <p class="text-xs text-cream-200 uppercase tracking-wider">Fragancias</p>
          </div>
          <div class="text-center hover:scale-110 transition-transform duration-300">
            <p class="text-2xl md:text-3xl font-bold text-cream-300">100%</p>
            <p class="text-xs text-cream-200 uppercase tracking-wider">Originales</p>
          </div>
          <div class="text-center hover:scale-110 transition-transform duration-300">
            <p class="text-2xl md:text-3xl font-bold text-cream-300">24/7</p>
            <p class="text-xs text-cream-200 uppercase tracking-wider">Atención</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categorías Rápidas -->
  <section id="categorias" class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-playfair text-2xl md:text-3xl text-brown-800 font-bold text-center mb-8 animate-fade-in">
        Categorías
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        <a
          href="/?categoria=caballero"
          class="group relative overflow-hidden rounded-2xl bg-cream-100 hover:bg-cream-200 p-6 md:p-8 text-center hover:shadow-xl transition-all duration-500 transform hover:-translate-y-2 hover:scale-105 block border border-cream-200 animate-slide-up"
          :style="{ animationDelay: '0.1s' }"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6b4221" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <h3 class="font-playfair text-lg md:text-xl font-bold text-brown-700">Caballero</h3>
          <p class="text-xs text-brown-400 mt-1">Fragancias masculinas</p>
        </a>

        <a
          href="/?categoria=damas"
          class="group relative overflow-hidden rounded-2xl bg-cream-100 hover:bg-cream-200 p-6 md:p-8 text-center hover:shadow-xl transition-all duration-500 transform hover:-translate-y-2 hover:scale-105 block border border-cream-200 animate-slide-up"
          :style="{ animationDelay: '0.2s' }"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6b4221" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
          <h3 class="font-playfair text-lg md:text-xl font-bold text-brown-700">Damas</h3>
          <p class="text-xs text-brown-400 mt-1">Fragancias femeninas</p>
        </a>

        <a
          href="/?categoria=unisex"
          class="group relative overflow-hidden rounded-2xl bg-cream-100 hover:bg-cream-200 p-6 md:p-8 text-center hover:shadow-xl transition-all duration-500 transform hover:-translate-y-2 hover:scale-105 block border border-cream-200 animate-slide-up"
          :style="{ animationDelay: '0.3s' }"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6b4221" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          <h3 class="font-playfair text-lg md:text-xl font-bold text-brown-700">Unisex</h3>
          <p class="text-xs text-brown-400 mt-1">Para todos</p>
        </a>

        <a
          href="/?categoria=sets"
          class="group relative overflow-hidden rounded-2xl bg-cream-100 hover:bg-cream-200 p-6 md:p-8 text-center hover:shadow-xl transition-all duration-500 transform hover:-translate-y-2 hover:scale-105 block border border-cream-200 animate-slide-up"
          :style="{ animationDelay: '0.4s' }"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6b4221" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
            <rect x="3" y="8" width="18" height="12" rx="2"/>
            <path d="M3 8V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/>
            <path d="M12 6v14"/>
            <path d="M8 6V4"/>
            <path d="M16 6V4"/>
          </svg>
          <h3 class="font-playfair text-lg md:text-xl font-bold text-brown-700">Sets</h3>
          <p class="text-xs text-brown-400 mt-1">Combos especiales</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Productos -->
  <section id="productos" class="py-12 md:py-16 bg-cream-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="font-playfair text-2xl md:text-3xl text-brown-800 font-bold animate-fade-in">
          Nuestra Colección
        </h2>
        <p class="text-brown-400 text-sm mt-1 animate-fade-in">
          Encuentra tu fragancia perfecta
        </p>
      </div>
      <ProductGrid client:load />
    </div>
  </section>

  <!-- WhatsApp Flotante -->
  <a
    href="https://wa.me/584127050149"
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-40 bg-green-500 hover:bg-green-400 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-110 hover:rotate-12 animate-fade-in"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
  </a>
</Layout>