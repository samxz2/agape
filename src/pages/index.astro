---
import Layout from '../layouts/Layout.astro'
import ProductGrid from '../components/ProductGrid.vue'
import { productos } from '../data/productos'

const totalProductos = productos.length
const counts: Record<string, number> = {}
for (const p of productos) {
  counts[p.categoria] = (counts[p.categoria] || 0) + 1
}
const categorias = [
  { id: 'caballero', label: 'Caballero', desc: 'Fragancias masculinas', count: counts.caballero || 0 },
  { id: 'dama', label: 'Damas', desc: 'Fragancias femeninas', count: counts.dama || 0 },
  { id: 'unisex', label: 'Unisex', desc: 'Para todos', count: counts.unisex || 0 },
  { id: 'sets', label: 'Sets', desc: 'Combos especiales', count: counts.sets || 0 },
]
---

<Layout title="Agape Collection Parfum">
  <!-- HERO -->
  <section
    class="relative min-h-[60vh] md:min-h-[70vh] flex items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_top,#5c3a25,transparent_60%),linear-gradient(to_bottom,#351f14,#22120b)]"
  >
    <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
      <p class="text-cream-300 uppercase tracking-[0.4em] text-xs md:text-sm mb-4 animate-fade-in-up" style="animation-delay: 0s">
        Bienvenido a
      </p>

      <h1 class="font-playfair text-5xl md:text-7xl text-cream-50 font-bold leading-tight animate-fade-in-up" style="animation-delay: 0.1s">
        Agape
        <span class="block text-gold-300">
          Collection
        </span>
      </h1>

      <p class="font-playfair italic text-xl md:text-3xl text-cream-200 mt-3 animate-fade-in-up" style="animation-delay: 0.2s">
        Parfum
      </p>

      <p class="max-w-2xl mx-auto mt-4 text-sm md:text-base text-cream-200/80 leading-relaxed animate-fade-in-up" style="animation-delay: 0.3s">
        Descubre nuestra exclusiva colección de perfumes para caballero,
        damas, unisex y sets.
      </p>

      <!-- Stats -->
      <div class="flex items-center justify-center gap-6 md:gap-10 mt-6 animate-fade-in-up" style="animation-delay: 0.35s">
        <div class="text-center">
          <p class="text-gold-300 text-xl md:text-2xl font-bold font-playfair">{totalProductos}+</p>
          <p class="text-cream-300/60 text-[10px] md:text-xs uppercase tracking-wider">Productos</p>
        </div>
        <div class="w-px h-8 bg-cream-300/20"></div>
        <div class="text-center">
          <p class="text-gold-300 text-xl md:text-2xl font-bold font-playfair">4</p>
          <p class="text-cream-300/60 text-[10px] md:text-xs uppercase tracking-wider">Categorías</p>
        </div>
        <div class="w-px h-8 bg-cream-300/20"></div>
        <div class="text-center">
          <p class="text-gold-300 text-xl md:text-2xl font-bold font-playfair">🇻🇪</p>
          <p class="text-cream-300/60 text-[10px] md:text-xs uppercase tracking-wider">Envío Venezuela</p>
        </div>
      </div>

      <!-- BOTONES -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="#productos"
          class="bg-gradient-to-r from-brown-700 to-brown-600 hover:from-brown-600 hover:to-brown-500 text-cream-50 font-semibold rounded-2xl transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-0.5 active:scale-95 px-8 py-4 text-sm uppercase tracking-widest"
        >
          Explorar Colección
        </a>

        <a
          href="#categorias"
          class="border border-cream-300/40 hover:border-gold-300 text-cream-100 hover:text-gold-300 rounded-2xl transition-all duration-300 px-8 py-4 text-sm uppercase tracking-widest"
        >
          Ver Categorías
        </a>
      </div>
    </div>

    <!-- blur decor -->
    <div class="absolute top-0 left-0 w-72 h-72 bg-gold-300/10 blur-3xl rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-72 h-72 bg-brown-300/10 blur-3xl rounded-full"></div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- CATEGORIAS -->
  <section id="categorias" class="py-14 md:py-18 bg-[#fffdf9]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-playfair text-3xl md:text-4xl text-brown-800 font-bold">
          Categorías
        </h2>
        <p class="text-brown-400 text-sm mt-2">
          Explora nuestra selección exclusiva
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-5">
        {categorias.map((cat) => (
          <a
            href={`/?categoria=${cat.id}`}
            class="group relative bg-white rounded-[28px] border border-cream-200 hover:border-gold-300 p-5 md:p-7 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl text-center overflow-hidden"
          >
            <!-- Count badge -->
            <span class="absolute top-3 right-3 bg-cream-100 text-brown-500 text-[10px] font-bold px-2 py-0.5 rounded-full group-hover:bg-gold-300 group-hover:text-brown-900 transition-colors duration-300">
              {cat.count}
            </span>

            <!-- Icon -->
            <div class="w-12 h-12 md:w-14 md:h-14 mx-auto mb-3 rounded-2xl bg-cream-100 flex items-center justify-center group-hover:bg-gradient-to-br group-hover:from-brown-700 group-hover:to-brown-600 transition-all duration-500">
              {cat.id === 'caballero' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brown-600 group-hover:text-cream-100 transition-colors duration-500">
                  <path d="M12 2a5 5 0 1 0 0 10 5 5 0 0 0 0-10z"/>
                  <path d="M2 22c0-5 5-8 10-8s10 3 10 8"/>
                </svg>
              )}
              {cat.id === 'dama' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brown-600 group-hover:text-cream-100 transition-colors duration-500">
                  <circle cx="12" cy="8" r="3"/>
                  <path d="M6 21v-6a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v6"/>
                  <path d="M8 14s-2-2-4-2"/>
                  <path d="M16 14s2-2 4-2"/>
                  <path d="M9 5a3 3 0 0 1 6 0"/>
                </svg>
              )}
              {cat.id === 'unisex' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brown-600 group-hover:text-cream-100 transition-colors duration-500">
                  <path d="M12 2l1.8 5.2L19 9l-5.2 1.8L12 16l-1.8-5.2L5 9l5.2-1.8L12 2z"/>
                  <path d="M19 16l.9 2.1L22 19l-2.1.9L19 22l-.9-2.1L16 19l2.1-.9L19 16z"/>
                  <path d="M5 16l.9 2.1L8 19l-2.1.9L5 22l-.9-2.1L2 19l2.1-.9L5 16z"/>
                </svg>
              )}
              {cat.id === 'sets' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brown-600 group-hover:text-cream-100 transition-colors duration-500">
                  <rect x="3" y="8" width="18" height="12" rx="2"/>
                  <path d="M3 8V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/>
                  <path d="M12 6v14"/>
                </svg>
              )}
            </div>

            <h3 class="font-playfair text-lg md:text-xl text-brown-700 font-bold">
              {cat.label}
            </h3>
            <p class="text-[11px] md:text-xs text-brown-400 mt-1">{cat.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- PRODUCTOS -->
  <section id="productos" class="py-14 md:py-18 bg-gradient-to-b from-cream-50 to-cream-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="font-playfair text-3xl md:text-4xl text-brown-800 font-bold">
          Nuestra Colección
        </h2>
        <p class="text-brown-400 text-sm mt-2">
          Encuentra tu fragancia ideal · <span class="font-semibold text-brown-500">{totalProductos}</span> productos disponibles
        </p>
      </div>

      <ProductGrid client:visible />
    </div>
  </section>

  <!-- WHATSAPP -->
  <a
    href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMERO || '584127050149'}`}
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-40 bg-gradient-to-br from-green-500 to-green-600 hover:from-green-400 hover:to-green-500 text-white w-14 h-14 md:w-16 md:h-16 rounded-full flex items-center justify-center shadow-[0_8px_30px_rgba(34,197,94,0.35)] hover:shadow-[0_12px_40px_rgba(34,197,94,0.5)] hover:scale-110 active:scale-95 transition-all duration-300 animate-pulse-subtle"
    aria-label="Contactar por WhatsApp"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
  </a>

  <!-- Back to top -->
  <button
    id="back-to-top"
    class="fixed bottom-24 right-6 z-40 bg-brown-700 hover:bg-brown-600 text-cream-50 w-10 h-10 rounded-full flex items-center justify-center shadow-lg transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    aria-label="Volver arriba"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <style>
    #back-to-top.is-visible {
      opacity: 1 !important;
      transform: translateY(0) !important;
      pointer-events: auto !important;
    }
  </style>

  <script>
    (function() {
      const btn = document.getElementById('back-to-top')
      if (!btn) return
      let ticking = false
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            btn.classList.toggle('is-visible', window.scrollY > 600)
            ticking = false
          })
          ticking = true
        }
      }, { passive: true })
    })()
  </script>
</Layout>