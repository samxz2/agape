---
import Layout from '../layouts/Layout.astro'
import ProductGrid from '../components/ProductGrid.vue'
import { productos } from '../data/productos'
import { WHATSAPP_NUMERO } from '../data/config'

const totalProductos = productos.length
const SITE_URL = 'https://agapecollectionparfum.com'

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Agape Collection Parfum',
      url: SITE_URL,
      logo: 'https://i.ibb.co/CpHdX08t/1001879919.png',
      sameAs: [
        `https://wa.me/${WHATSAPP_NUMERO}`,
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: `+${WHATSAPP_NUMERO}`,
        contactType: 'sales',
        availableLanguage: ['Spanish'],
      },
    },
    {
      '@type': 'WebSite',
      name: 'Agape Collection Parfum',
      url: SITE_URL,
      description: 'Fragancias exclusivas de lujo. Perfumes originales para caballero, damas, unisex y sets.',
      potentialAction: {
        '@type': 'SearchAction',
        target: `${SITE_URL}/?buscar={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'ItemList',
      name: 'Catálogo de Perfumes',
      description: `${totalProductos} productos disponibles en Agape Collection Parfum`,
      url: SITE_URL,
      numberOfItems: totalProductos,
      itemListElement: productos.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'Product',
          name: p.nombre,
          description: p.descripcion,
          image: p.imagen,
          category: p.categoria,
          offers: {
            '@type': 'Offer',
            price: p.enOferta && p.precioOferta ? p.precioOferta : p.precio,
            priceCurrency: 'USD',
            availability: p.estadoEnvio === 'disponible'
              ? 'https://schema.org/InStock'
              : 'https://schema.org/OutOfStock',
          },
        },
      })),
    },
  ],
}
---

<Layout title="Agape Collection Parfum" canonical={SITE_URL}>
  <script is:inline set:html={JSON.stringify(jsonLd)} type="application/ld+json" />

  <!-- HERO -->
  <section
    class="relative min-h-[85vh] md:min-h-screen flex items-center justify-center overflow-hidden pt-20 bg-gradient-to-b from-cream-100 via-cream-50 to-cream-100"
  >
    <!-- Ambient glow -->
    <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-gold-400/10 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-brown-200/15 blur-[120px] rounded-full"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-cream-200/20 blur-[200px] rounded-full"></div>

    <!-- Decorative corner flourishes -->
    <div class="absolute top-10 left-10 w-24 h-24 opacity-20 pointer-events-none">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 10 C10 10, 30 10, 50 30 C70 50, 90 90, 90 90" stroke="#8b5e3a" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M90 10 C90 10, 70 10, 50 30 C30 50, 10 90, 10 90" stroke="#8b5e3a" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="50" cy="50" r="2" fill="#8b5e3a"/>
      </svg>
    </div>
    <div class="absolute bottom-10 right-10 w-24 h-24 opacity-20 pointer-events-none rotate-180">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 10 C10 10, 30 10, 50 30 C70 50, 90 90, 90 90" stroke="#8b5e3a" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M90 10 C90 10, 70 10, 50 30 C30 50, 10 90, 10 90" stroke="#8b5e3a" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="50" cy="50" r="2" fill="#8b5e3a"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
      <!-- Decorative line above -->
      <div class="flex items-center justify-center gap-3 mb-8 animate-fade-in-up">
        <span class="w-8 h-px bg-gold-400/40"></span>
        <span class="text-brown-400 uppercase tracking-[0.4em] text-xs md:text-sm font-medium">Bienvenido a</span>
        <span class="w-8 h-px bg-gold-400/40"></span>
      </div>

      <h1 class="font-playfair text-5xl md:text-7xl lg:text-8xl font-bold leading-tight animate-fade-in-up" style="animation-delay: 0.1s">
        <span class="text-brown-700">Agape</span>
        <span class="block text-gold-400 mt-1 md:mt-2 tracking-wide">
          Collection
        </span>
      </h1>

      <!-- Decorative divider -->
      <div class="flex items-center justify-center gap-2 mt-5 mb-5 animate-fade-in-up" style="animation-delay: 0.15s">
        <span class="w-12 h-px bg-brown-200"></span>
        <span class="text-brown-300 text-xs">✦</span>
        <span class="w-12 h-px bg-brown-200"></span>
      </div>

      <p class="font-playfair italic text-xl md:text-3xl text-brown-400 animate-fade-in-up font-light" style="animation-delay: 0.2s">
        Parfum
      </p>

      <p class="max-w-2xl mx-auto mt-5 text-sm md:text-base text-brown-500/80 leading-relaxed animate-fade-in-up" style="animation-delay: 0.3s">
        Descubre nuestra exclusiva colección de perfumes originales para caballero,
        damas, unisex y sets.
        <span class="block mt-3 text-gold-500/70 text-xs uppercase tracking-[0.25em] font-semibold">Toda compra al mayor tiene descuento para pagos en divisa</span>
      </p>

      <!-- Stats -->
      <div class="flex items-center justify-center gap-6 md:gap-14 mt-8 animate-fade-in-up" style="animation-delay: 0.35s">
        <div class="text-center">
          <p class="text-gold-400 text-2xl md:text-3xl font-bold font-playfair">{totalProductos}+</p>
          <p class="text-brown-400/60 text-[10px] md:text-xs uppercase tracking-wider mt-1">Productos</p>
        </div>
        <div class="w-px h-10 bg-gradient-to-b from-transparent via-brown-200 to-transparent"></div>
        <div class="text-center">
          <p class="text-gold-400 text-2xl md:text-3xl font-bold font-playfair">4</p>
          <p class="text-brown-400/60 text-[10px] md:text-xs uppercase tracking-wider mt-1">Categorías</p>
        </div>
        <div class="w-px h-10 bg-gradient-to-b from-transparent via-brown-200 to-transparent"></div>
        <div class="text-center">
          <p class="text-2xl md:text-3xl">🇻🇪</p>
          <p class="text-brown-400/60 text-[10px] md:text-xs uppercase tracking-wider mt-1">Envío Venezuela</p>
        </div>
      </div>

      <!-- BOTONES -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 animate-fade-in-up" style="animation-delay: 0.4s">
        <a
          href="#productos"
          class="group relative bg-brown-600 hover:bg-brown-500 text-cream-50 font-bold rounded-2xl transition-all duration-300 shadow-lg shadow-brown-600/20 hover:shadow-xl hover:shadow-brown-600/30 hover:-translate-y-0.5 active:scale-[0.97] px-8 py-4 text-sm uppercase tracking-widest overflow-hidden"
        >
          <span class="relative z-10">Explorar Colección</span>
          <span class="absolute inset-0 bg-gradient-to-r from-brown-500 to-brown-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
        </a>

        <a
          href="#productos"
          class="group relative bg-transparent text-brown-600 hover:text-brown-500 rounded-2xl transition-all duration-300 px-8 py-4 text-sm uppercase tracking-widest border border-brown-300/50 hover:border-gold-400/60 overflow-hidden"
        >
          <span class="relative z-10">Ver Categorías</span>
          <span class="absolute inset-0 bg-cream-50/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section transition -->
  <div class="section-divider max-w-4xl mx-auto"></div>

  <!-- PRODUCTOS -->
  <section id="productos" class="py-14 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-brown-400 uppercase tracking-[0.3em] text-xs mb-3 font-medium">Colección</p>
        <h2 class="font-playfair text-3xl md:text-4xl text-brown-700 font-bold">
          Nuestra Colección
        </h2>
        <div class="w-16 h-0.5 bg-gold-400 rounded-full mx-auto mt-4"></div>
        <p class="text-brown-500 text-sm mt-4">
          Encuentra tu fragancia ideal · <span class="font-semibold text-gold-500">{totalProductos}</span> productos disponibles
        </p>
      </div>

      <ProductGrid client:load />
    </div>
  </section>

  <!-- WHATSAPP -->
  <a
    href={'https://wa.me/' + (import.meta.env.PUBLIC_WHATSAPP_NUMERO || '584127050149')}
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-40 bg-gradient-to-br from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 text-white w-14 h-14 md:w-16 md:h-16 rounded-full flex items-center justify-center shadow-[0_8px_30px_rgba(34,197,94,0.25)] hover:shadow-[0_12px_40px_rgba(34,197,94,0.4)] hover:scale-110 active:scale-95 transition-all duration-300"
    aria-label="Contactar por WhatsApp"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
  </a>

  <!-- Back to top -->
  <button
    id="back-to-top"
    class="fixed bottom-24 right-6 z-40 bg-dark-700 hover:bg-dark-600 text-dark-200 hover:text-gold-300 w-10 h-10 rounded-full flex items-center justify-center shadow-lg border border-border transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    aria-label="Volver arriba"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <script>
    const btn = document.getElementById('back-to-top')
    if (btn) {
      window.addEventListener('scroll', () => {
        const show = window.scrollY > 600
        btn.classList.toggle('opacity-100', show)
        btn.classList.toggle('translate-y-0', show)
        btn.classList.toggle('opacity-0', !show)
        btn.classList.toggle('translate-y-4', !show)
        btn.classList.toggle('pointer-events-none', !show)
      })
    }
  </script>
</Layout>